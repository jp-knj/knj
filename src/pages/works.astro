---
import Layout from "../layouts/Layout.astro";
import typo from "../styles/typograhy.module.css";

const works = [
  {
    year: "2026",
    month: "Feb",
    title: "Hosted the first official Astro Japan Meetup",
    description:
      'Organized the <a href="https://astrojp.connpass.com/event/376291/" target="_blank" rel="noopener noreferrer">inaugural in-person community event</a> in Tokyo with global speakers.',
  },
  {
    year: "2025",
    month: "Nov",
    title: "Founded Astro Japan Community as the official chapter",
    description:
      'Launched the <a href="https://astrojp.connpass.com/" target="_blank" rel="noopener noreferrer">local community</a> to grow the Astro ecosystem within the Japanese market.',
  },
  {
    year: "2025",
    month: "Oct",
    title: "Appointed as an official Maintainer for Astro",
    description:
      'Became the first Japanese maintainer, focusing on core code and internationalization. Announced in the <a href="https://astro.build/blog/whats-new-october-2025/" target="_blank" rel="noopener noreferrer">October 2025 newsletter</a>.',
  },
  {
    year: "2025",
    month: "Sep",
    title: "Gave a Lightning Talk at Frontend Conference Tokyo",
    description:
      'Presented at <a href="https://fec-tokyo.github.io/2025/" target="_blank" rel="noopener noreferrer">Frontend Conference Tokyo 2025</a>.',
  },
  {
    year: "2024",
    month: "Sep",
    title: "Joined Plaid, Inc. and led Astro migration",
    description:
      "Directed a large-scale framework transition, reducing client-side JS by 70 percent.",
  },
  {
    year: "2023",
    month: "May",
    title: 'Published "Introduction to Design Systems" on Zenn',
    description:
      'Released a <a href="https://zenn.dev/ignorant_kenji/books/introduction-to-design-systems" target="_blank" rel="noopener noreferrer">technical book</a> that received over 1,000 likes for its insightful content.',
  },
  {
    year: "2022",
    month: "Nov",
    title: "Launched a design system project at Basic Inc.",
    description:
      "Initiated and led the development of a reusable UI component library and guidelines.",
  },
  {
    year: "2022",
    month: "Aug",
    title: "Started professional career as a software engineer",
    description:
      "Began his journey in engineering, focusing on bridging design and development.",
  },
];

const years = [...new Set(works.map((w) => w.year))];
---

<Layout title="Works | Kenji">
    <section class="page-section" id="works">
        {
            years.map((year) => (
                <div class="year-group">
                    <h2 class:list={["works-header", typo.sectionTitle]}>
                        {year}
                    </h2>
                    <ul class="timeline">
                        {works
                            .filter((w) => w.year === year)
                            .map((item, i) => (
                                <li
                                    class="timeline-item reveal"
                                    style={`animation-delay: ${i * 0.04}s`}
                                >
                                    <span
                                        class:list={[
                                            "timeline-date",
                                            typo.metaText,
                                        ]}
                                    >
                                        {item.month}
                                    </span>
                                    <div class="timeline-content">
                                        <span
                                            class:list={[
                                                "timeline-title",
                                                typo.cardTitle,
                                            ]}
                                        >
                                            {item.title}
                                        </span>
                                        <span
                                            class:list={[
                                                "timeline-desc",
                                                typo.linkText,
                                            ]}
                                            set:html={item.description}
                                        />
                                    </div>
                                </li>
                            ))}
                    </ul>
                </div>
            ))
        }
    </section>
</Layout>

<style>
    .year-group {
        margin-bottom: 24px;
    }

    .year-group:last-child {
        margin-bottom: 0;
    }

    .works-header {
        font-family: "Syne", sans-serif;
        font-weight: 700;
        margin-bottom: 8px;
        color: #ffffff;
    }

    .works-header::after {
        content: "";
        display: block;
        width: 32px;
        height: 2px;
        background: linear-gradient(90deg, var(--accent), transparent);
        margin-top: 8px;
        border-radius: 2px;
    }

    .timeline {
        list-style: none;
        padding: 0;
        margin: 0;
    }

    .timeline-item {
        display: flex;
        align-items: baseline;
        padding: 12px 0;
        border-bottom: 1px solid var(--tab-border);
    }

    .timeline-item:last-child {
        border-bottom: none;
    }

    .timeline-date {
        width: 40px;
        flex-shrink: 0;
        color: var(--accent);
        font-family: "DM Mono", monospace;
    }

    .timeline-content {
        display: flex;
        flex-direction: column;
        gap: 8px;
        line-height: 1.6;
    }

    .timeline-title {
        font-weight: 600;
        color: var(--fg-sub);
    }

    .timeline-desc {
        color: var(--fg-muted);
    }

    .timeline-desc :global(a) {
        color: var(--fg-sub);
        transition: color 0.25s ease;
    }

    .timeline-desc :global(a:hover) {
        color: var(--accent);
    }

    .reveal {
        opacity: 0;
        animation: workFadeIn 0.2s ease-out forwards;
    }

    @keyframes workFadeIn {
        from {
            opacity: 0;
        }
        to {
            opacity: 1;
        }
    }

    @media (max-width: 520px) {
        .timeline-item {
            flex-direction: column;
        }

        .timeline-date {
            margin-bottom: 4px;
        }
    }
</style>
